{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Benchmark Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "commit_sha",
    "spec_version",
    "tool_version",
    "claim_mode",
    "representation",
    "corpus_manifest",
    "corpus_manifest_hash",
    "generated_at",
    "scir_h_lineage_references",
    "tracks",
    "explicit_representation_metrics",
    "compressed_representation_metrics",
    "claim_class",
    "evidence_class",
    "claim_gate",
    "failure_attribution",
    "claims",
    "disclaimers",
    "artifacts",
    "reproducibility_block"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "claim_mode": {
      "type": "string",
      "enum": [
        "smoke",
        "claim"
      ]
    },
    "representation": {
      "type": "string",
      "const": "SCIR-Hc"
    },
    "corpus_manifest": {
      "type": "string",
      "minLength": 1
    },
    "corpus_manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "scir_h_lineage_references": {
      "$ref": "#/$defs/scirHcLineageReferences"
    },
    "tracks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "A",
        "B"
      ],
      "properties": {
        "A": {
          "type": "string",
          "enum": [
            "pass",
            "mixed",
            "fail"
          ]
        },
        "B": {
          "type": "string",
          "enum": [
            "pass",
            "mixed",
            "fail"
          ]
        }
      }
    },
    "explicit_representation_metrics": {
      "$ref": "#/$defs/explicitMetrics"
    },
    "compressed_representation_metrics": {
      "$ref": "#/$defs/compressedMetrics"
    },
    "claim_class": {
      "type": "string",
      "enum": [
        "LEXICAL_COMPRESSION_ONLY",
        "GRAMMAR_REGULARITY_ONLY",
        "PATCH_COMPOSABILITY_ONLY"
      ]
    },
    "evidence_class": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "scirhc_lcr_vs_ast",
          "scirhc_gr_vs_ast",
          "patch_composability_vs_ast"
        ]
      }
    },
    "claim_gate": {
      "$ref": "#/$defs/claimGate"
    },
    "failure_attribution": {
      "$ref": "#/$defs/failureAttribution"
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "disclaimers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "$ref": "#/$defs/reportArtifacts"
    },
    "reproducibility_block": {
      "$ref": "#/$defs/reproducibilityBlock"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "representation": {
            "const": "SCIR-Hc"
          }
        }
      },
      "then": {
        "required": [
          "scir_h_lineage_references",
          "evidence_class"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "semantic_claims"
              ]
            },
            {
              "required": [
                "authoritative_metrics"
              ]
            },
            {
              "required": [
                "lowering_artifacts"
              ]
            },
            {
              "required": [
                "backend_outputs"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_class": {
            "const": "LEXICAL_COMPRESSION_ONLY"
          }
        }
      },
      "then": {
        "properties": {
          "evidence_class": {
            "items": {
              "const": "scirhc_lcr_vs_ast"
            }
          },
          "claim_gate": {
            "properties": {
              "satisfied_conditions": {
                "items": {
                  "const": "scirhc_lcr_vs_ast"
                }
              },
              "evaluated_conditions": {
                "items": {
                  "properties": {
                    "id": {
                      "const": "scirhc_lcr_vs_ast"
                    },
                    "metric": {
                      "const": "LCR_scirhc"
                    }
                  }
                }
              }
            }
          },
          "claims": {
            "items": {
              "properties": {
                "metric": {
                  "const": "LCR_scirhc"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_class": {
            "const": "GRAMMAR_REGULARITY_ONLY"
          }
        }
      },
      "then": {
        "properties": {
          "evidence_class": {
            "items": {
              "const": "scirhc_gr_vs_ast"
            }
          },
          "claim_gate": {
            "properties": {
              "satisfied_conditions": {
                "items": {
                  "const": "scirhc_gr_vs_ast"
                }
              },
              "evaluated_conditions": {
                "items": {
                  "properties": {
                    "id": {
                      "const": "scirhc_gr_vs_ast"
                    },
                    "metric": {
                      "const": "GR_scirhc"
                    }
                  }
                }
              }
            }
          },
          "claims": {
            "items": {
              "properties": {
                "metric": {
                  "const": "GR_scirhc"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_class": {
            "const": "PATCH_COMPOSABILITY_ONLY"
          }
        }
      },
      "then": {
        "properties": {
          "evidence_class": {
            "items": {
              "const": "patch_composability_vs_ast"
            }
          },
          "claim_gate": {
            "properties": {
              "satisfied_conditions": {
                "items": {
                  "const": "patch_composability_vs_ast"
                }
              },
              "evaluated_conditions": {
                "items": {
                  "properties": {
                    "id": {
                      "const": "patch_composability_vs_ast"
                    },
                    "metric": {
                      "enum": [
                        "patch_composability_gain_vs_typed_ast",
                        "SCPR_scirhc"
                      ]
                    }
                  }
                }
              }
            }
          },
          "claims": {
            "items": {
              "properties": {
                "metric": {
                  "enum": [
                    "patch_composability_gain_vs_typed_ast",
                    "SCPR_scirhc"
                  ]
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "scirHcLineageReferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture.python_importer.a_basic_function",
        "fixture.python_importer.a_async_await",
        "fixture.python_importer.b_direct_call",
        "fixture.python_importer.c_opaque_call"
      ],
      "properties": {
        "fixture.python_importer.a_basic_function": {
          "$ref": "#/$defs/lineageReference"
        },
        "fixture.python_importer.a_async_await": {
          "$ref": "#/$defs/lineageReference"
        },
        "fixture.python_importer.b_direct_call": {
          "$ref": "#/$defs/lineageReference"
        },
        "fixture.python_importer.c_opaque_call": {
          "$ref": "#/$defs/lineageReference"
        }
      }
    },
    "lineageReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_lineage_id",
        "normalized_canonical_hash"
      ],
      "properties": {
        "semantic_lineage_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "normalized_canonical_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "reportArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_summary",
        "contamination_report",
        "scirhc_diff_audit",
        "sweep_result"
      ],
      "properties": {
        "comparison_summary": {
          "type": "string",
          "minLength": 1
        },
        "contamination_report": {
          "type": "string",
          "minLength": 1
        },
        "scirhc_diff_audit": {
          "type": "string",
          "minLength": 1
        },
        "sweep_result": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "explicitMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "LCR",
        "GR",
        "SE",
        "SCPR",
        "round_trip"
      ],
      "properties": {
        "LCR": {
          "type": [
            "number",
            "null"
          ]
        },
        "GR": {
          "type": [
            "number",
            "null"
          ]
        },
        "SE": {
          "type": [
            "number",
            "null"
          ]
        },
        "SCPR": {
          "type": [
            "number",
            "null"
          ]
        },
        "round_trip": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "compressedMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "LCR_scirhc",
        "GR_scirhc",
        "SCPR_scirhc"
      ],
      "properties": {
        "LCR_scirhc": {
          "type": [
            "number",
            "null"
          ]
        },
        "GR_scirhc": {
          "type": [
            "number",
            "null"
          ]
        },
        "SCPR_scirhc": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "corpus_manifest",
        "corpus_manifest_hash",
        "baseline_name",
        "metric",
        "metric_class",
        "scir_h_evidence",
        "observed_value",
        "baseline_value",
        "delta",
        "confidence_range"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "corpus_manifest": {
          "type": "string",
          "minLength": 1
        },
        "corpus_manifest_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "baseline_name": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "metric_class": {
          "type": "string",
          "enum": [
            "DESCRIPTIVE",
            "EVALUATIVE",
            "CAUSAL"
          ]
        },
        "scir_h_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "fixture.python_importer.a_basic_function",
              "fixture.python_importer.a_async_await",
              "fixture.python_importer.b_direct_call",
              "fixture.python_importer.c_opaque_call"
            ]
          }
        },
        "observed_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "baseline_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "confidence_range": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "low": {
              "type": "number"
            },
            "high": {
              "type": "number"
            }
          }
        }
      }
    },
    "claimCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "baseline_name",
        "metric",
        "metric_class",
        "scir_h_evidence",
        "observed_value",
        "baseline_value",
        "delta",
        "threshold",
        "comparison",
        "passed"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "baseline_name": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "metric_class": {
          "type": "string",
          "enum": [
            "DESCRIPTIVE",
            "EVALUATIVE",
            "CAUSAL"
          ]
        },
        "scir_h_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "fixture.python_importer.a_basic_function",
              "fixture.python_importer.a_async_await",
              "fixture.python_importer.b_direct_call",
              "fixture.python_importer.c_opaque_call"
            ]
          }
        },
        "observed_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "baseline_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "threshold": {
          "type": "number"
        },
        "comparison": {
          "type": "string",
          "enum": [
            "lt",
            "ge",
            "gt"
          ]
        },
        "passed": {
          "type": "boolean"
        }
      }
    },
    "claimGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "ai_thesis_status",
        "satisfied_conditions",
        "evaluated_conditions"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "ai_thesis_status": {
          "type": "string",
          "enum": [
            "supported",
            "invalidated"
          ]
        },
        "satisfied_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evaluated_conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claimCondition"
          }
        }
      }
    },
    "failureAttribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_cause",
        "token_inflation",
        "structural_redundancy",
        "unavoidable_explicitness"
      ],
      "properties": {
        "primary_cause": {
          "type": "string",
          "enum": [
            "none",
            "token_inflation",
            "structural_redundancy",
            "unavoidable_explicitness"
          ]
        },
        "token_inflation": {
          "type": "number"
        },
        "structural_redundancy": {
          "type": "number"
        },
        "unavoidable_explicitness": {
          "type": "number"
        }
      }
    },
    "reproducibilityBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "environment",
        "seed",
        "timestamp"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
