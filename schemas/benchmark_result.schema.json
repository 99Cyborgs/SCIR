{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Benchmark Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_id",
    "run_id",
    "commit_sha",
    "spec_version",
    "tool_version",
    "system_under_test",
    "track",
    "baseline_name",
    "corpus_manifest_hash",
    "metrics",
    "baseline_comparison",
    "artifact_rows",
    "reproducibility_block",
    "status"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "system_under_test": {
      "type": "string",
      "minLength": 1
    },
    "track": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "baseline_name": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": [
        "R",
        "N",
        "P",
        "D-PY",
        "D-JS"
      ]
    },
    "corpus_manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "baseline_comparison": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "artifact_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/auditRow"
      }
    },
    "reproducibility_block": {
      "$ref": "#/$defs/reproducibilityBlock"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "mixed",
        "fail"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "metricValue": {
      "type": [
        "number",
        "string",
        "boolean",
        "null"
      ]
    },
    "reproducibilityBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "environment",
        "seed",
        "timestamp"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "auditRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "commit_sha",
        "spec_version",
        "tool_version",
        "baseline_name",
        "corpus_manifest_hash",
        "artifact_id",
        "slice_id",
        "stage",
        "metrics",
        "preservation_requested",
        "preservation_observed",
        "diagnostic_codes",
        "compile_pass",
        "test_pass",
        "duration_ms",
        "reproducibility_block"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "commit_sha": {
          "type": "string",
          "minLength": 1
        },
        "spec_version": {
          "type": "string",
          "minLength": 1
        },
        "tool_version": {
          "type": "string",
          "minLength": 1
        },
        "baseline_name": {
          "type": "string",
          "minLength": 1
        },
        "corpus_manifest_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "slice_id": {
          "type": "string",
          "minLength": 1
        },
        "frontend": {
          "type": "string"
        },
        "tier": {
          "type": "string"
        },
        "split": {
          "type": "string"
        },
        "origin": {
          "type": "string"
        },
        "sample_class": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "construct_family": {
          "type": "string"
        },
        "fixture_set": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": [
            "source_to_h",
            "scir_h_validation",
            "h_to_l",
            "scir_l_validation",
            "h_to_python",
            "l_to_wasm"
          ]
        },
        "status": {
          "type": "string"
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/metricValue"
          }
        },
        "preservation_requested": {
          "type": [
            "string",
            "null"
          ]
        },
        "preservation_observed": {
          "type": [
            "string",
            "null"
          ]
        },
        "preservation_expected": {
          "type": [
            "string",
            "null"
          ]
        },
        "preservation_expectation_status": {
          "type": "string"
        },
        "preservation_downgrade_count": {
          "type": "integer",
          "minimum": 0
        },
        "boundary_annotation_count": {
          "type": "integer",
          "minimum": 0
        },
        "opaque_fraction": {
          "type": [
            "number",
            "null"
          ]
        },
        "unsupported_fraction": {
          "type": [
            "number",
            "null"
          ]
        },
        "unsupported_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diagnostic_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compile_pass": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "test_pass": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "reproducibility_block": {
          "$ref": "#/$defs/reproducibilityBlock"
        }
      }
    }
  }
}
