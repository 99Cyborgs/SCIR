{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Benchmark Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_id",
    "run_id",
    "system_under_test",
    "track",
    "metrics",
    "baseline_comparison",
    "status"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "system_under_test": {
      "type": "string",
      "minLength": 1
    },
    "track": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "profile": {
      "type": "string",
      "enum": [
        "R",
        "N",
        "P",
        "D"
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "baseline_comparison": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "mixed",
        "fail"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
