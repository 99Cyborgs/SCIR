{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Corpus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "corpus_id",
    "kind",
    "fixtures"
  ],
  "properties": {
    "corpus_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "active_roundtrip",
        "negative_validation"
      ]
    },
    "split_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "simulated_no_training",
            "explicit_train_dev_test"
          ]
        },
        "train": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dev": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "test": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "language",
          "path",
          "tier",
          "expected_support",
          "expected_preservation_ceiling",
          "features",
          "hash"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string",
            "enum": [
              "python",
              "rust",
              "scir_h",
              "scir_l"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          },
          "expected_support": {
            "type": "string",
            "enum": [
              "roundtrip",
              "importer_only",
              "boundary_only",
              "importer_evidence",
              "reject"
            ]
          },
          "expected_preservation_ceiling": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3",
              "PX"
            ]
          },
          "expected_preservation_stage_behavior": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "source_to_h": {
                "$ref": "#/$defs/preservationStageBehavior"
              },
              "scir_h_validation": {
                "$ref": "#/$defs/preservationStageBehavior"
              },
              "h_to_l": {
                "$ref": "#/$defs/preservationStageBehavior"
              },
              "scir_l_validation": {
                "$ref": "#/$defs/preservationStageBehavior"
              },
              "h_to_python": {
                "$ref": "#/$defs/preservationStageBehavior"
              },
              "l_to_wasm": {
                "$ref": "#/$defs/preservationStageBehavior"
              }
            }
          },
          "features": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "frontend": {
            "type": "string"
          },
          "split": {
            "type": "string",
            "enum": [
              "train",
              "dev",
              "test"
            ]
          },
          "origin": {
            "type": "string",
            "minLength": 1
          },
          "sample_class": {
            "type": "string",
            "enum": [
              "real",
              "synthetic"
            ]
          },
          "profiles": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "R",
                "N",
                "P",
                "D-PY",
                "D-JS"
              ]
            }
          },
          "pipeline_stages": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "source_to_h",
                "scir_h_validation",
                "h_to_l",
                "scir_l_validation",
                "h_to_python",
                "l_to_wasm"
              ]
            }
          },
          "construct_family": {
            "type": "string"
          },
          "fixture_set": {
            "type": "string"
          },
          "unsupported_tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected_diagnostic_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[HLT][0-9]{3}$"
            }
          },
          "boundary_contract_path": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "preservationStageBehavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "preservation_level"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail",
            "skip"
          ]
        },
        "preservation_level": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "PX"
          ]
        }
      }
    }
  }
}
