{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Decision Register Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisions"
  ],
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "decision",
          "constraint_imposed",
          "reversible",
          "first_validation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "accepted",
              "pending",
              "superseded",
              "rejected"
            ]
          },
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "constraint_imposed": {
            "type": "string",
            "minLength": 1
          },
          "reversible": {
            "type": "string",
            "enum": [
              "yes",
              "no",
              "partly"
            ]
          },
          "first_validation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
