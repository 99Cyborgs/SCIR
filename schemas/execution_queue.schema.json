{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Execution Queue Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generation_timestamp",
    "active_milestone",
    "autonomy_mode",
    "source_documents",
    "queue_items",
    "blocking_open_questions",
    "next_action",
    "escalation_threshold"
  ],
  "properties": {
    "generation_timestamp": {
      "type": "string",
      "minLength": 1
    },
    "active_milestone": {
      "type": "string",
      "minLength": 1
    },
    "autonomy_mode": {
      "type": "string",
      "enum": [
        "high",
        "moderate",
        "conservative"
      ]
    },
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "queue_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "queue_id",
          "title",
          "source_milestone_or_phase",
          "status",
          "why_now",
          "prerequisites",
          "work_instructions",
          "touched_surfaces",
          "validation",
          "escalate_only_if",
          "done_evidence",
          "blocking_open_questions"
        ],
        "properties": {
          "queue_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_milestone_or_phase": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ready",
              "blocked",
              "in-progress",
              "done",
              "deferred"
            ]
          },
          "why_now": {
            "type": "string",
            "minLength": 1
          },
          "prerequisites": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "work_instructions": {
            "type": "string",
            "minLength": 1
          },
          "touched_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "validation": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "escalate_only_if": {
            "type": "string",
            "minLength": 1
          },
          "done_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "blocking_open_questions": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^OQ-[0-9]{3}$"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "blocking_open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OQ-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_id",
        "title"
      ],
      "properties": {
        "queue_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "escalation_threshold": {
      "type": "string",
      "minLength": 1
    }
  }
}
