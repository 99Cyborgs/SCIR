{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Feature Tier Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "subject",
    "source_language",
    "summary",
    "items"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "source_language": {
      "type": "string",
      "enum": [
        "python",
        "rust",
        "typescript",
        "go",
        "c++",
        "haskell",
        "unknown"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "A",
        "B",
        "C",
        "D"
      ],
      "properties": {
        "A": {
          "type": "integer",
          "minimum": 0
        },
        "B": {
          "type": "integer",
          "minimum": 0
        },
        "C": {
          "type": "integer",
          "minimum": 0
        },
        "D": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "feature",
          "tier",
          "rationale"
        ],
        "properties": {
          "feature": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "fallback": {
            "type": "string"
          }
        }
      }
    }
  }
}
