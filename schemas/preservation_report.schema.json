{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Preservation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "subject",
    "path",
    "source_artifact",
    "target_artifact",
    "profile",
    "preservation_level",
    "status",
    "downgrades",
    "boundary_annotations",
    "evidence"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "enum": [
        "source_to_h",
        "h_to_l",
        "h_to_python",
        "l_to_wasm"
      ]
    },
    "source_artifact": {
      "type": "string",
      "minLength": 1
    },
    "target_artifact": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": [
        "R",
        "N",
        "P",
        "D-PY",
        "D-JS"
      ]
    },
    "preservation_level": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3",
        "PX"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "mixed",
        "fail"
      ]
    },
    "downgrades": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reason",
          "preservation_level"
        ],
        "properties": {
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "preservation_level": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3",
              "PX"
            ]
          }
        }
      }
    },
    "boundary_annotations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observables": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserved",
        "normalized",
        "contract_bounded",
        "opaque",
        "unsupported"
      ],
      "properties": {
        "preserved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "normalized": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contract_bounded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "opaque": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsupported": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
