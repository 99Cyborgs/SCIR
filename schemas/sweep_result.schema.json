{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Sweep Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sweep_id",
    "run_id",
    "commit_sha",
    "spec_version",
    "tool_version",
    "corpus_id",
    "corpus_manifest_hash",
    "generated_at",
    "rows",
    "baseline_rows",
    "clusters",
    "reproducibility_block"
  ],
  "properties": {
    "sweep_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "corpus_id": {
      "type": "string",
      "minLength": 1
    },
    "corpus_manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/auditRow"
      }
    },
    "baseline_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/auditRow"
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "count"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "reproducibility_block": {
      "$ref": "#/$defs/reproducibilityBlock"
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_run_id",
        "regressions",
        "resolved"
      ],
      "properties": {
        "baseline_run_id": {
          "type": "string",
          "minLength": 1
        },
        "regressions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureDelta"
          }
        },
        "resolved": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureDelta"
          }
        }
      }
    }
  },
  "$defs": {
    "metricValue": {
      "type": [
        "number",
        "string",
        "boolean",
        "null"
      ]
    },
    "reproducibilityBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "environment",
        "seed",
        "timestamp"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failureDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "stage",
        "from_status",
        "to_status"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "from_status": {
          "type": "string",
          "minLength": 1
        },
        "to_status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "auditRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "commit_sha",
        "spec_version",
        "tool_version",
        "baseline_name",
        "corpus_manifest_hash",
        "artifact_id",
        "frontend",
        "tier",
        "split",
        "origin",
        "sample_class",
        "profile",
        "construct_family",
        "fixture_set",
        "slice_id",
        "stage",
        "status",
        "diagnostic_codes",
        "metrics",
        "preservation_requested",
        "preservation_expected",
        "preservation_observed",
        "preservation_expectation_status",
        "preservation_downgrade_count",
        "boundary_annotation_count",
        "opaque_fraction",
        "unsupported_fraction",
        "unsupported_tags",
        "compile_pass",
        "test_pass",
        "duration_ms",
        "reproducibility_block"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "commit_sha": {
          "type": "string",
          "minLength": 1
        },
        "spec_version": {
          "type": "string",
          "minLength": 1
        },
        "tool_version": {
          "type": "string",
          "minLength": 1
        },
        "baseline_name": {
          "type": "string",
          "minLength": 1
        },
        "corpus_manifest_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "frontend": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C",
            "D"
          ]
        },
        "split": {
          "type": "string",
          "enum": [
            "train",
            "dev",
            "test"
          ]
        },
        "origin": {
          "type": "string",
          "minLength": 1
        },
        "sample_class": {
          "type": "string",
          "enum": [
            "real",
            "synthetic"
          ]
        },
        "profile": {
          "type": "string",
          "enum": [
            "R",
            "N",
            "P",
            "D-PY",
            "D-JS"
          ]
        },
        "construct_family": {
          "type": "string",
          "minLength": 1
        },
        "fixture_set": {
          "type": "string",
          "minLength": 1
        },
        "slice_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "enum": [
            "source_to_h",
            "scir_h_validation",
            "h_to_l",
            "scir_l_validation",
            "h_to_python",
            "l_to_wasm"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail",
            "skip"
          ]
        },
        "diagnostic_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_-]+$"
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/metricValue"
          }
        },
        "preservation_requested": {
          "type": [
            "string",
            "null"
          ]
        },
        "preservation_expected": {
          "type": [
            "string",
            "null"
          ]
        },
        "preservation_observed": {
          "type": [
            "string",
            "null"
          ]
        },
        "preservation_expectation_status": {
          "type": "string",
          "enum": [
            "match",
            "justified_downgrade",
            "unexplained_downgrade",
            "overclaim",
            "status_mismatch",
            "missing_observation",
            "not_configured",
            "not_applicable"
          ]
        },
        "preservation_downgrade_count": {
          "type": "integer",
          "minimum": 0
        },
        "boundary_annotation_count": {
          "type": "integer",
          "minimum": 0
        },
        "opaque_fraction": {
          "type": [
            "number",
            "null"
          ]
        },
        "unsupported_fraction": {
          "type": [
            "number",
            "null"
          ]
        },
        "unsupported_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compile_pass": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "test_pass": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "reproducibility_block": {
          "$ref": "#/$defs/reproducibilityBlock"
        }
      }
    }
  }
}
