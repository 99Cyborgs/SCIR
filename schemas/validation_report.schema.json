{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCIR Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "artifact",
    "layer",
    "validator",
    "status",
    "diagnostics"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "repo",
        "scir_h",
        "scir_l",
        "translation",
        "benchmark"
      ]
    },
    "validator": {
      "type": "string",
      "minLength": 1
    },
    "spec_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "error"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "node_id": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        }
      }
    }
  }
}
